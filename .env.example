# Copy this file to .env and fill only the broker you want to use.
# Never commit real API keys or access tokens.

PORT=8787
HOST=127.0.0.1
ALLOWED_ORIGINS=http://127.0.0.1:8787,http://localhost:8787
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=90

# Active broker for paper-trade market data: dhan, zerodha, upstox, angel, fyers, custom, mock
ACTIVE_BROKER=mock

# DhanHQ market data
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Zerodha Kite market data
ZERODHA_API_KEY=
ZERODHA_ACCESS_TOKEN=

# Upstox market data
UPSTOX_ACCESS_TOKEN=

# Angel One SmartAPI market data
ANGEL_CLIENT_ID=
ANGEL_API_KEY=
ANGEL_ACCESS_TOKEN=
ANGEL_FEED_TOKEN=

# Fyers market data
FYERS_CLIENT_ID=
FYERS_ACCESS_TOKEN=

# Custom quote proxy
CUSTOM_QUOTE_URL=
CUSTOM_AUTH_HEADER=
